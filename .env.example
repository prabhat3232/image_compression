# Copy to .env and fill in values (never commit .env)
SITE_URL=https://fileshrinkr.com
FLASK_SECRET_KEY=generate-a-random-secret
FLASK_ENV=production
PORT=3000

# Public contact address shown on site
CONTACT_EMAIL=xspace.dummy@gmail.com

# Option A: Gmail SMTP (often blocked on port 465/587 by ISP or hosting)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Option B: Google Apps Script webhook URL (recommended if SMTP times out)
# See temp/contact-email-apps-script.js for setup
CONTACT_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbyy0VOkuhAX1-N1D0gAhIoFxM5UHpLYfD3xohBzzkTHSzbPlRAkc4Bhy2awPqQ58UM/exec
